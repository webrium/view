{
    "name": "webrium/view",
    "description": "Lightweight PHP template engine with hybrid static caching (no eval) for the Webrium framework.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BEN Khalife",
            "email": "benkhalife@proton.me"
        }
    ],
    "homepage": "https://github.com/webrium/view",
    "support": {
        "issues": "https://github.com/webrium/view/issues",
        "source": "https://github.com/webrium/view"
    },
    "scripts": {
        "tests": "./vendor/bin/phpunit --testdox tests"
    },
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Webrium\\View\\": "src/",
            "Webrium\\View\\EditorJs\\": "src/EditorJs/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Webrium\\View\\Tests\\": "tests/",
            "Webrium\\View\\EditorJs\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "phpunit/phpunit": "^12"
    }
}